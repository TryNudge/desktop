{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Nudge",
  "version": "0.2.2",
  "identifier": "com.nudge.app",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "splash",
        "title": "Nudge",
        "width": 420,
        "height": 340,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "center": true,
        "url": "pages/splash.html",
        "backgroundColor": "#00000000"
      },
      {
        "label": "input",
        "title": "Nudge",
        "width": 500,
        "height": 48,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true,
        "url": "pages/input.html",
        "backgroundColor": "#00000000"
      },
      {
        "label": "overlay",
        "title": "Nudge Overlay",
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "fullscreen": false,
        "focus": false,
        "url": "pages/overlay.html",
        "backgroundColor": "#00000000"
      },
      {
        "label": "control",
        "title": "Nudge Controls",
        "width": 460,
        "height": 42,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "url": "pages/control.html",
        "backgroundColor": "#00000000"
      },
      {
        "label": "answer",
        "title": "Nudge Answer",
        "width": 480,
        "height": 420,
        "minWidth": 360,
        "minHeight": 280,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true,
        "url": "pages/answer.html",
        "backgroundColor": "#00000000"
      },
      {
        "label": "settings",
        "title": "Nudge Settings",
        "width": 480,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "visible": false,
        "center": true,
        "url": "pages/settings.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": ["nsis"],
    "externalBin": ["binaries/sidecar"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "languages": ["English"],
        "startMenuFolder": "Nudge"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nudge"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/TryNudge/desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1RTEzRjYxMDk1MEM1MTQKUldRVXhWQUpZVC9oTldtQWJqbGEwQjNMbGp5THpRbGZBVTZ1dlRKZ0I2bEJmQUU1TkcvckIvekwK"
    }
  }
}
