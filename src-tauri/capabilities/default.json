{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/nicegui/native/tauri_config/schema/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Nudge",
  "windows": ["splash", "input", "overlay", "control", "settings", "answer", "dashboard"],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-center",
    "core:window:allow-set-focus",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-available-monitors",
    "core:window:allow-current-monitor",
    "core:window:allow-set-background-color",
    "core:window:allow-set-shadow",
    "core:window:allow-minimize",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:event:allow-listen",
    "global-shortcut:default",
    "shell:default"
  ]
}
